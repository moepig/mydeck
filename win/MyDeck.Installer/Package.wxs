<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui"
     xmlns:util="http://wixtoolset.org/schemas/v4/wxs/util">

  <Package Name="!(loc.ProductName)"
           Manufacturer="!(loc.Manufacturer)"
           Version="1.0.0.0"
           UpgradeCode="4D454B44-0001-0000-C000-000000000046"
           Language="1033"
           Compressed="yes">

    <SummaryInformation Keywords="Installer" />

    <!--
      同一 UpgradeCode の旧バージョンを自動削除し、新バージョンへアップグレードする。
      ダウングレードはエラーとして弾く。
    -->
    <MajorUpgrade DowngradeErrorMessage="!(loc.DowngradeError)" />

    <MediaTemplate EmbedCab="yes" />

    <!-- インストール先: %ProgramFiles%\MyDeck\ -->
    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="MyDeck" />
    </StandardDirectory>

    <!-- スタートメニュー: MyDeck フォルダ -->
    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="AppMenuFolder" Name="MyDeck" />
    </StandardDirectory>

    <!-- デスクトップ -->
    <StandardDirectory Id="DesktopFolder" />

    <!--
      発行済み出力ディレクトリ内の全ファイルを自動収集する。
      ビルド前に dotnet publish -p:PublishProfile=installer を実行しておくこと。
    -->
    <ComponentGroup Id="AppFiles" Directory="INSTALLFOLDER">
      <Files Include="$(var.PublishDir)**" />
    </ComponentGroup>

    <!-- スタートメニューショートカット -->
    <ComponentGroup Id="Shortcuts" Directory="AppMenuFolder">
      <Component Guid="*">
        <Shortcut Id="StartMenuShortcut"
                  Name="!(loc.ProductName)"
                  Target="[INSTALLFOLDER]MyDeck.exe"
                  WorkingDirectory="INSTALLFOLDER" />
        <RemoveFolder Id="RemoveAppMenuFolder" Directory="AppMenuFolder" On="uninstall" />
        <RegistryValue Root="HKCU"
                       Key="Software\MyDeck"
                       Name="ShortcutInstalled"
                       Value="1"
                       Type="integer"
                       KeyPath="yes" />
      </Component>
    </ComponentGroup>

    <!-- デスクトップショートカット（設定画面を直接開く） -->
    <ComponentGroup Id="DesktopShortcuts" Directory="DesktopFolder">
      <Component Guid="*">
        <Shortcut Id="DesktopShortcut"
                  Name="!(loc.ProductName)"
                  Target="[INSTALLFOLDER]MyDeck.exe"
                  Arguments="--settings"
                  WorkingDirectory="INSTALLFOLDER" />
        <RegistryValue Root="HKCU"
                       Key="Software\MyDeck"
                       Name="DesktopShortcutInstalled"
                       Value="1"
                       Type="integer"
                       KeyPath="yes" />
      </Component>
    </ComponentGroup>

    <!-- ログイン時自動起動（HKCU Run） -->
    <ComponentGroup Id="AutoStart" Directory="INSTALLFOLDER">
      <Component Guid="*">
        <RegistryValue Root="HKCU"
                       Key="Software\Microsoft\Windows\CurrentVersion\Run"
                       Name="MyDeck"
                       Value="[INSTALLFOLDER]MyDeck.exe"
                       Type="string"
                       KeyPath="yes" />
      </Component>
    </ComponentGroup>

    <Feature Id="ProductFeature" Title="!(loc.ProductName)" Level="1">
      <ComponentGroupRef Id="AppFiles" />
      <ComponentGroupRef Id="Shortcuts" />
      <ComponentGroupRef Id="AutoStart" />

      <!-- デスクトップショートカット（任意） -->
      <Feature Id="DesktopShortcutFeature" Title="!(loc.DesktopShortcutFeature)" Level="1">
        <ComponentGroupRef Id="DesktopShortcuts" />
      </Feature>
    </Feature>

    <!-- インストーラー UI（機能選択画面を含む） -->
    <ui:WixUI Id="WixUI_FeatureTree" />
    <WixVariable Id="WixUILicenseRtf" Value="License.rtf" />

  </Package>

</Wix>
